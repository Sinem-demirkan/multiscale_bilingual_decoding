#!/usr/bin/env Rscript

suppressPackageStartupMessages({
  library(lme4)
})

parse_args = function() {
  args = commandArgs(trailingOnly = TRUE)
  out = list()

  i = 1
  while (i <= length(args)) {
    key = args[[i]]
    if (!startsWith(key, "--")) {
      stop(paste("Unexpected argument:", key))
    }
    if (i == length(args)) {
      stop(paste("Missing value for", key))
    }
    out[[sub("^--", "", key)]] = args[[i + 1]]
    i = i + 2
  }

  required = c("transfer", "self-decoding", "qc", "metadata", "out-dir")
  missing = setdiff(required, names(out))
  if (length(missing) > 0) {
    stop(paste("Missing required arguments:", paste(missing, collapse = ", ")))
  }

  out
}

zscore_with = function(x, center, scale_value) {
  (x - center) / scale_value
}

train_standardizer = function(subject_covariates, train_subjects) {
  train_cov = subject_covariates[subject_covariates$subject %in% train_subjects, ]
  list(
    selfacc_mean = mean(train_cov$selfacc),
    selfacc_sd = sd(train_cov$selfacc),
    tsnr_mean = mean(train_cov$tsnr),
    tsnr_sd = sd(train_cov$tsnr)
  )
}

add_standardized_terms = function(df, scaler) {
  df$teacher_selfacc_z = zscore_with(df$teacher_selfacc, scaler$selfacc_mean, scaler$selfacc_sd)
  df$learner_selfacc_z = zscore_with(df$learner_selfacc, scaler$selfacc_mean, scaler$selfacc_sd)
  df$teacher_tsnr_z = zscore_with(df$teacher_tsnr, scaler$tsnr_mean, scaler$tsnr_sd)
  df$learner_tsnr_z = zscore_with(df$learner_tsnr, scaler$tsnr_mean, scaler$tsnr_sd)
  df
}

fixed_predict = function(dat, beta) {
  beta[["(Intercept)"]] +
    beta[["teacher_selfacc_z"]] * dat$teacher_selfacc_z +
    beta[["learner_selfacc_z"]] * dat$learner_selfacc_z +
    beta[["teacher_tsnr_z"]] * dat$teacher_tsnr_z +
    beta[["learner_tsnr_z"]] * dat$learner_tsnr_z +
    beta[["teacher_selfacc_z:teacher_tsnr_z"]] * dat$teacher_selfacc_z * dat$teacher_tsnr_z +
    beta[["learner_selfacc_z:learner_tsnr_z"]] * dat$learner_selfacc_z * dat$learner_tsnr_z
}

score_model = function(model_name, observed, predicted) {
  ok = is.finite(observed) & is.finite(predicted)
  observed = observed[ok]
  predicted = predicted[ok]

  r_test = cor.test(observed, predicted)
  spearman_test = suppressWarnings(cor.test(observed, predicted, method = "spearman"))
  cv_r2 = 1 - sum((observed - predicted)^2) / sum((observed - mean(observed))^2)

  data.frame(
    model = model_name,
    n = length(observed),
    pearson_r = unname(r_test$estimate),
    pearson_p = r_test$p.value,
    spearman_rho = unname(spearman_test$estimate),
    spearman_p = spearman_test$p.value,
    cv_r2 = cv_r2
  )
}

loo_lm_predictions = function(subject_df, predictors, outcome, model_name) {
  cols = c("subject", outcome, predictors)
  dat = subject_df[, cols]
  dat = dat[complete.cases(dat), ]

  rows = list()
  for (target in dat$subject) {
    train = dat[dat$subject != target, ]
    test = dat[dat$subject == target, ]

    formula = as.formula(paste(outcome, "~", paste(predictors, collapse = " + ")))
    fit = lm(formula, data = train)
    pred = predict(fit, newdata = test)

    rows[[length(rows) + 1]] = data.frame(
      subject = target,
      observed = test[[outcome]],
      predicted = as.numeric(pred),
      model = model_name
    )
  }

  do.call(rbind, rows)
}

args = parse_args()
out_dir = args[["out-dir"]]
dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)

transfer = read.csv(args[["transfer"]], stringsAsFactors = FALSE)
self = read.csv(args[["self-decoding"]], stringsAsFactors = FALSE)
qc = read.csv(args[["qc"]], stringsAsFactors = FALSE)
metadata = read.csv(args[["metadata"]], stringsAsFactors = FALSE)

self = self[, c("subject", "balanced_accuracy")]
names(self)[names(self) == "balanced_accuracy"] = "selfacc"

qc = qc[, c("subject", "mean_tsnr")]
names(qc)[names(qc) == "mean_tsnr"] = "tsnr"

metadata = metadata[, c("subject", "AoA")]

subject_df = merge(metadata, self, by = "subject")
subject_df = merge(subject_df, qc, by = "subject")

if ("local-extent" %in% names(args)) {
  local = read.csv(args[["local-extent"]], stringsAsFactors = FALSE)
  local_cols = intersect(c("subject", "prop_z_gt_1p64"), names(local))
  if (!all(c("subject", "prop_z_gt_1p64") %in% local_cols)) {
    stop("--local-extent must contain subject and prop_z_gt_1p64")
  }
  subject_df = merge(subject_df, local[, c("subject", "prop_z_gt_1p64")], by = "subject")
}

subject_covariates = subject_df[, c("subject", "selfacc", "tsnr")]

df0 = transfer
if ("same_subject" %in% names(df0)) {
  df0 = df0[df0$same_subject %in% c(FALSE, "False", "FALSE", 0), ]
} else {
  df0 = df0[df0$train_subject != df0$test_subject, ]
}

df0$teacher = df0$train_subject
df0$learner = df0$test_subject

df0 = merge(df0, setNames(self, c("teacher", "teacher_selfacc")), by = "teacher")
df0 = merge(df0, setNames(self, c("learner", "learner_selfacc")), by = "learner")
df0 = merge(df0, setNames(qc, c("teacher", "teacher_tsnr")), by = "teacher")
df0 = merge(df0, setNames(qc, c("learner", "learner_tsnr")), by = "learner")

subjects = sort(intersect(unique(df0$teacher), subject_df$subject))

fit_formula = balanced_accuracy ~
  teacher_selfacc_z + learner_selfacc_z +
  teacher_tsnr_z + learner_tsnr_z +
  teacher_selfacc_z:teacher_tsnr_z +
  learner_selfacc_z:learner_tsnr_z +
  (1 | teacher) + (1 | learner)

fold_rows = list()
effect_rows = list()

for (target in subjects) {
  train_subjects = setdiff(subjects, target)
  scaler = train_standardizer(subject_covariates, train_subjects)

  train_pairs = df0[
    df0$teacher %in% train_subjects & df0$learner %in% train_subjects,
  ]
  train_pairs = add_standardized_terms(train_pairs, scaler)

  fit = lmer(fit_formula, data = train_pairs, REML = TRUE)

  teacher_re = ranef(fit)$teacher
  learner_re = ranef(fit)$learner
  teacher_blup = setNames(teacher_re[, 1], rownames(teacher_re))
  learner_blup = setNames(learner_re[, 1], rownames(learner_re))
  beta = fixef(fit)

  train_effects = data.frame(
    subject = train_subjects,
    teacher_effect = as.numeric(teacher_blup[train_subjects]),
    learner_effect = as.numeric(learner_blup[train_subjects])
  )
  train_effects = merge(train_effects, subject_df, by = "subject", all.x = TRUE)

  out_rows = df0[df0$teacher == target & df0$learner %in% train_subjects, ]
  out_rows = add_standardized_terms(out_rows, scaler)
  out_fixed = fixed_predict(out_rows, beta)
  heldout_teacher = mean(
    out_rows$balanced_accuracy - out_fixed - learner_blup[out_rows$learner]
  )

  in_rows = df0[df0$learner == target & df0$teacher %in% train_subjects, ]
  in_rows = add_standardized_terms(in_rows, scaler)
  in_fixed = fixed_predict(in_rows, beta)
  heldout_learner = mean(
    in_rows$balanced_accuracy - in_fixed - teacher_blup[in_rows$teacher]
  )

  target_row = subject_df[subject_df$subject == target, ][1, ]

  fit_teacher = lm(AoA ~ teacher_effect, data = train_effects)
  fit_learner = lm(AoA ~ learner_effect, data = train_effects)
  fit_both = lm(AoA ~ teacher_effect + learner_effect, data = train_effects)
  fit_learner_self = lm(AoA ~ learner_effect + selfacc, data = train_effects)

  pred_teacher = predict(fit_teacher, newdata = data.frame(teacher_effect = heldout_teacher))
  pred_learner = predict(fit_learner, newdata = data.frame(learner_effect = heldout_learner))
  pred_both = predict(
    fit_both,
    newdata = data.frame(
      teacher_effect = heldout_teacher,
      learner_effect = heldout_learner
    )
  )
  pred_learner_self = predict(
    fit_learner_self,
    newdata = data.frame(
      learner_effect = heldout_learner,
      selfacc = target_row$selfacc
    )
  )

  fold_rows[[length(fold_rows) + 1]] = data.frame(
    subject = target,
    observed = target_row$AoA,
    pred_teacher_effect = as.numeric(pred_teacher),
    pred_learner_effect = as.numeric(pred_learner),
    pred_teacher_plus_learner = as.numeric(pred_both),
    pred_learner_plus_selfdecoding = as.numeric(pred_learner_self)
  )

  effect_rows[[length(effect_rows) + 1]] = data.frame(
    subject = target,
    AoA = target_row$AoA,
    teacher_effect = heldout_teacher,
    learner_effect = heldout_learner,
    selfacc = target_row$selfacc,
    tsnr = target_row$tsnr
  )

  cat("Finished nested AoA fold for", target, "\n")
}

transfer_predictions = do.call(rbind, fold_rows)
transfer_effects = do.call(rbind, effect_rows)

long_predictions = rbind(
  data.frame(
    subject = transfer_predictions$subject,
    observed = transfer_predictions$observed,
    predicted = transfer_predictions$pred_teacher_effect,
    model = "Teacher effect"
  ),
  data.frame(
    subject = transfer_predictions$subject,
    observed = transfer_predictions$observed,
    predicted = transfer_predictions$pred_learner_effect,
    model = "Learner effect"
  ),
  data.frame(
    subject = transfer_predictions$subject,
    observed = transfer_predictions$observed,
    predicted = transfer_predictions$pred_teacher_plus_learner,
    model = "Teacher + Learner"
  ),
  data.frame(
    subject = transfer_predictions$subject,
    observed = transfer_predictions$observed,
    predicted = transfer_predictions$pred_learner_plus_selfdecoding,
    model = "Learner + self-decoding"
  )
)

baseline_predictions = list(
  loo_lm_predictions(subject_df, c("selfacc"), "AoA", "Self whole-cortex")
)

if ("prop_z_gt_1p64" %in% names(subject_df)) {
  baseline_predictions[[length(baseline_predictions) + 1]] =
    loo_lm_predictions(subject_df, c("prop_z_gt_1p64"), "AoA", "Local extent")
}

all_predictions = rbind(do.call(rbind, baseline_predictions), long_predictions)

summary_rows = do.call(
  rbind,
  lapply(
    split(all_predictions, all_predictions$model),
    function(x) score_model(x$model[1], x$observed, x$predicted)
  )
)
summary_rows = summary_rows[order(summary_rows$cv_r2, decreasing = TRUE), ]

write.csv(transfer_predictions, file.path(out_dir, "age_of_acquisition_nested_lme4_predictions_wide.csv"), row.names = FALSE)
write.csv(all_predictions, file.path(out_dir, "age_of_acquisition_nested_lme4_predictions_long.csv"), row.names = FALSE)
write.csv(summary_rows, file.path(out_dir, "age_of_acquisition_nested_lme4_summary.csv"), row.names = FALSE)
write.csv(transfer_effects, file.path(out_dir, "nested_transfer_effects_by_fold.csv"), row.names = FALSE)

print(summary_rows)
